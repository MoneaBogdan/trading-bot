# === News-driven strategy credentials ===
# Copy to `.env.news` (gitignored via .env*) and fill in real values.
# Used by:
#   - src/recorders/news_recorder.py
#   - src/bots/news_alpha_runner.py
#   - src/strategies/news_alpha/backtest.py

# --- News source selection ---
# 'treeofalpha_rest' (default) — polls https://news.treeofalpha.com/api/news.
#                                Free, no auth, no .session file. Latency ~2-3 min.
# 'telegram'                   — Telethon listener; requires the TG_* block below.
NEWS_SOURCE=treeofalpha_rest

# --- Tree of Alpha REST poller (only used when NEWS_SOURCE=treeofalpha_rest) ---
TOA_POLL_INTERVAL_S=5
# TOA_REST_URL=https://news.treeofalpha.com/api/news   # override if needed

# --- Telegram (Telethon) — only used when NEWS_SOURCE=telegram ---
# Get from https://my.telegram.org/apps after logging in with your phone number.
TG_API_ID=
TG_API_HASH=

# Session file basename. The .session file holds your Telegram auth — treat
# like a credential. Gitignored via *.session.
TG_SESSION_NAME=tree_news_recorder

# Comma-separated channel usernames (no @). Join from your Telegram account
# first. ⚠ Telegram has many Tree-of-Alpha impersonators; verify the channel
# before trusting it (look at message volume and content quality, not subs).
TG_CHANNELS=

# --- Anthropic (Claude Sonnet classifier) ---
ANTHROPIC_API_KEY=

# --- Strategy tunables (all optional; defaults shown) ---
# Confidence floor for Claude classification before considering a fire.
NEWS_MIN_CONFIDENCE=0.70

# Seconds between fires across all news events.
NEWS_COOLDOWN_S=60

# Polymarket ask band — skip if ask outside [sweet_lo, sweet_hi].
NEWS_SWEET_LO=0.30
NEWS_SWEET_HI=0.40

# Don't fire on markets resolving more than N minutes out.
NEWS_MAX_HORIZON_MIN=60

# Daily fire cap (defense in depth on top of POLY_MAX_DAILY_USDC).
NEWS_MAX_FIRES_PER_DAY=10

# --- Polymarket creds (same as polymarket/.env — re-listed here so the
#     runner can load a single .env.news file at boot. Set the SAME values.) ---
POLY_PRIVATE_KEY=
POLY_FUNDER_ADDRESS=
POLY_MAX_ORDER_USDC=5
POLY_MAX_DAILY_USDC=20
POLY_DRY_RUN=true
