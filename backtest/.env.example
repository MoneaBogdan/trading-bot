# Get from https://www.oanda.com/account/demo (free, instant).
# Manage API tokens at: Account > Manage API Access on the demo dashboard.
OANDA_API_TOKEN=
OANDA_ACCOUNT_ID=

# practice = demo, trade = live. Default practice.
OANDA_ENV=practice

# Optional: point at regime-classifier output so backtests can use the gate.
REGIME_CACHE_PATH=../regime-classifier/regime_cache.json
