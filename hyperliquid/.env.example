# Hyperliquid funding-arb bot config.
# Phase 1 (monitor-only) needs NO secrets — all reads are public REST/WS.
# Phase 2+ adds signing credentials below.

# --- Phase 1: monitor tunables ---

# Poll interval for funding-rate reads (seconds). HL accrues hourly,
# Binance every 8h, so anything <60s is overkill — pick a value that gives
# enough samples to catch the spread shape without rate-limiting.
HL_POLL_INTERVAL_S=30

# Assets to monitor. Comma-separated. Universe restricted to majors
# until JELLY-style oracle risk is understood — DO NOT add alts here
# without re-reading RESEARCH_DAYTRADING_2026.md.
HL_ASSETS=BTC,ETH,SOL

# Spread threshold (per 8h) at which to log an "opportunity" event.
# Break-even is ~1.3 bps; 5 bps gives 3x headroom for slippage at small clips.
HL_OPPORTUNITY_BPS_8H=5

# Notional size used for paper-PnL accounting on opportunity events.
HL_PAPER_NOTIONAL_USDC=1000

# --- Phase 2: execution (NOT used yet) ---

# Set to false ONLY after phase-1 paper-PnL passes the go-live gates
# documented in README.md. Default true — no real orders.
HL_DRY_RUN=true

# Wallet that signs HL orders. EIP-712 typed-data, nonce = ms timestamp.
# Each running bot needs its own wallet (nonce collisions on multi-process).
# HL_PRIVATE_KEY=
# HL_WALLET_ADDRESS=

# Hard caps (defense in depth).
HL_MAX_NOTIONAL_PER_LEG_USDC=200
HL_MAX_DAILY_LOSS_USDC=50
