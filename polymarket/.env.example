# === Polymarket live-trading credentials ===
# Get these by following polymarket/HOSTING.md → "Wallet setup".
# NEVER commit this file with real values. .env is gitignored.

# Hex private key for a Polygon wallet you control. With or without 0x prefix.
POLY_PRIVATE_KEY=

# Optional: if you trade via a Polymarket proxy / Safe wallet, set its address.
# Leave empty if signing-key == funding-wallet.
POLY_FUNDER_ADDRESS=

# Risk caps (USDC)
POLY_MAX_ORDER_USDC=5
POLY_MAX_DAILY_USDC=50

# Set to "false" only when you're ready to place real orders.
POLY_DRY_RUN=true
